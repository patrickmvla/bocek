#!/bin/bash
# Bocek toggle script — registers/removes enforcement hooks in Claude Code settings
set -euo pipefail

# --- Dependencies ---
command -v jq >/dev/null 2>&1 || { echo "bocek requires jq. Install: brew install jq (mac) or apt install jq (linux)" >&2; exit 1; }

# --- Project root detection ---
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.git" ]; then
      echo "$dir"
      return
    fi
    dir=$(dirname "$dir")
  done
  echo "$PWD"
}

PROJECT_ROOT=$(find_project_root)

PRIMITIVES=(design research implementation debugging refactoring review)
MANAGED_MARKER="<!-- bocek:managed -->"
ENFORCE_CMD="~/.bocek/scripts/enforce-mode.sh"
BANNER_CMD="~/.bocek/scripts/session-banner.sh"
PRELOAD_CMD="~/.bocek/scripts/preload-calibration.sh"
PREFLIGHT_CMD="~/.bocek/scripts/preflight.sh"

# --- Commands ---

cmd_on() {
  local SETTINGS_FILE="$PROJECT_ROOT/.claude/settings.local.json"
  local COMMANDS_DIR="$PROJECT_ROOT/.claude/commands"

  # Ensure .claude/ directory exists
  mkdir -p "$PROJECT_ROOT/.claude"
  mkdir -p "$COMMANDS_DIR"

  # Read existing settings or default to empty object
  local CURRENT='{}'
  if [ -f "$SETTINGS_FILE" ]; then
    CURRENT=$(cat "$SETTINGS_FILE")
  fi

  # Backup before modifying
  if [ -f "$SETTINGS_FILE" ]; then
    cp "$SETTINGS_FILE" "${SETTINGS_FILE}.bocek-backup"
  fi

  # Merge Bocek hook entries (idempotent) — PreToolUse enforcement + SessionStart banner + UserPromptSubmit preload
  local BOCEK_HOOKS
  BOCEK_HOOKS=$(jq -n \
    --arg enforce "$ENFORCE_CMD" \
    --arg banner "$BANNER_CMD" \
    --arg preload "$PRELOAD_CMD" \
    '{
      pre: { matcher: "Edit|Write|Bash", hooks: [ { type: "command", command: $enforce, timeout: 5 } ] },
      start: { hooks: [ { type: "command", command: $banner, timeout: 5 } ] },
      prompt: { hooks: [ { type: "command", command: $preload, timeout: 5 } ] }
    }')

  local MERGED
  MERGED=$(echo "$CURRENT" | jq \
    --argjson bocek "$BOCEK_HOOKS" \
    --arg enforce "$ENFORCE_CMD" \
    --arg banner "$BANNER_CMD" \
    --arg preload "$PRELOAD_CMD" \
    '
    . as $base
    | ($base.hooks // {}) as $h
    | ($h.PreToolUse // []) as $pre
    | ($h.SessionStart // []) as $start
    | ($h.UserPromptSubmit // []) as $prompt
    | (if ($pre | map(select(.hooks[0].command == $enforce)) | length) > 0
       then $pre
       else $pre + [$bocek.pre] end) as $pre2
    | (if ($start | map(select(.hooks[0].command == $banner)) | length) > 0
       then $start
       else $start + [$bocek.start] end) as $start2
    | (if ($prompt | map(select(.hooks[0].command == $preload)) | length) > 0
       then $prompt
       else $prompt + [$bocek.prompt] end) as $prompt2
    | $base * { hooks: ($h + { PreToolUse: $pre2, SessionStart: $start2, UserPromptSubmit: $prompt2 }) }
  ')

  # Validate before writing
  if echo "$MERGED" | jq '.' > /dev/null 2>&1; then
    echo "$MERGED" | jq '.' > "$SETTINGS_FILE"
  else
    echo "bocek: ERROR — generated invalid JSON. Settings not modified." >&2
    echo "bocek: backup preserved at ${SETTINGS_FILE}.bocek-backup" >&2
    exit 1
  fi

  # Write slash commands (idempotent). Only overwrite files we manage; warn on conflicts.
  local skipped=()
  for p in "${PRIMITIVES[@]}"; do
    local cmd_file="$COMMANDS_DIR/$p.md"
    if [ -f "$cmd_file" ] && ! head -n 1 "$cmd_file" | grep -q "$MANAGED_MARKER"; then
      skipped+=("$p")
      continue
    fi
    cat > "$cmd_file" <<EOF
$MANAGED_MARKER
---
description: Load the Bocek $p primitive and enter $p mode
---

Run the preflight script first to get oriented (it sets the mode and prints vault state, project signals, and suggested references):

\`\`\`
bash $PREFLIGHT_CMD $p
\`\`\`

Then read \`~/.bocek/primitives/$p.md\` and operate per its instructions, applying the preflight orientation as your starting context. Read the eager references the preflight printed before responding to the human.
EOF
  done

  # Create mode file if it doesn't exist
  mkdir -p "$PROJECT_ROOT/.bocek"
  if [ ! -f "$PROJECT_ROOT/.bocek/mode" ]; then
    echo "idle" > "$PROJECT_ROOT/.bocek/mode"
  fi

  # Ensure gitignore covers settings.local.json
  if [ -f "$PROJECT_ROOT/.gitignore" ]; then
    grep -q "settings.local.json" "$PROJECT_ROOT/.gitignore" || echo ".claude/settings.local.json" >> "$PROJECT_ROOT/.gitignore"
  fi

  echo "bocek: hooks registered (PreToolUse enforcement + SessionStart banner + UserPromptSubmit calibration preload)."
  echo "bocek: slash commands installed at .claude/commands/ — /design, /research, /implementation, /debugging, /refactoring, /review"
  if [ "${#skipped[@]}" -gt 0 ]; then
    echo "bocek: skipped pre-existing unmanaged commands: ${skipped[*]} (remove them and re-run 'bocek on' to install)"
  fi
  echo "bocek: mode set to $(cat "$PROJECT_ROOT/.bocek/mode"). Use a slash command in Claude Code to load a primitive."
}

cmd_off() {
  local SETTINGS_FILE="$PROJECT_ROOT/.claude/settings.local.json"
  local COMMANDS_DIR="$PROJECT_ROOT/.claude/commands"

  # Remove Bocek-managed slash commands (only ones carrying the marker)
  local removed=()
  if [ -d "$COMMANDS_DIR" ]; then
    for p in "${PRIMITIVES[@]}"; do
      local cmd_file="$COMMANDS_DIR/$p.md"
      if [ -f "$cmd_file" ] && head -n 1 "$cmd_file" | grep -q "$MANAGED_MARKER"; then
        rm "$cmd_file"
        removed+=("$p")
      fi
    done
    # Clean up empty commands dir
    rmdir "$COMMANDS_DIR" 2>/dev/null || true
  fi

  if [ ! -f "$SETTINGS_FILE" ]; then
    if [ "${#removed[@]}" -gt 0 ]; then
      echo "bocek: slash commands removed: ${removed[*]}"
    fi
    echo "bocek: no settings.local.json found. Nothing else to remove."
    exit 0
  fi

  # Backup before modifying
  cp "$SETTINGS_FILE" "${SETTINGS_FILE}.bocek-backup"

  # Remove Bocek hook entries, preserve everything else
  local CLEANED
  CLEANED=$(cat "$SETTINGS_FILE" | jq \
    --arg enforce "$ENFORCE_CMD" \
    --arg banner "$BANNER_CMD" \
    --arg preload "$PRELOAD_CMD" \
    '
    (if .hooks.PreToolUse then
      .hooks.PreToolUse |= map(select(.hooks[0].command != $enforce))
      | if (.hooks.PreToolUse | length) == 0 then del(.hooks.PreToolUse) else . end
    else . end)
    | (if .hooks.SessionStart then
        .hooks.SessionStart |= map(select(.hooks[0].command != $banner))
        | if (.hooks.SessionStart | length) == 0 then del(.hooks.SessionStart) else . end
      else . end)
    | (if .hooks.UserPromptSubmit then
        .hooks.UserPromptSubmit |= map(select(.hooks[0].command != $preload))
        | if (.hooks.UserPromptSubmit | length) == 0 then del(.hooks.UserPromptSubmit) else . end
      else . end)
    | if (.hooks // {} | length) == 0 then del(.hooks) else . end
  ')

  # If result is empty object, delete the file
  if [ "$(echo "$CLEANED" | jq 'length')" -eq 0 ]; then
    rm "$SETTINGS_FILE"
    echo "bocek: hooks removed. settings.local.json deleted (was empty)."
  else
    echo "$CLEANED" | jq '.' > "$SETTINGS_FILE"
    echo "bocek: hooks removed. Other settings preserved."
  fi

  if [ "${#removed[@]}" -gt 0 ]; then
    echo "bocek: slash commands removed: ${removed[*]}"
  fi
}

cmd_status() {
  echo "=== Bocek Status ==="

  # Check hook registration
  local SETTINGS_FILE="$PROJECT_ROOT/.claude/settings.local.json"
  local has_enforce=0 has_banner=0 has_preload=0
  if [ -f "$SETTINGS_FILE" ]; then
    jq -e --arg cmd "$ENFORCE_CMD" '.hooks.PreToolUse[]? | select(.hooks[0].command == $cmd)' "$SETTINGS_FILE" >/dev/null 2>&1 && has_enforce=1
    jq -e --arg cmd "$BANNER_CMD"  '.hooks.SessionStart[]? | select(.hooks[0].command == $cmd)' "$SETTINGS_FILE" >/dev/null 2>&1 && has_banner=1
    jq -e --arg cmd "$PRELOAD_CMD" '.hooks.UserPromptSubmit[]? | select(.hooks[0].command == $cmd)' "$SETTINGS_FILE" >/dev/null 2>&1 && has_preload=1
  fi
  if [ "$has_enforce" -eq 1 ] && [ "$has_banner" -eq 1 ] && [ "$has_preload" -eq 1 ]; then
    echo "Hooks: registered (enforcement + banner + preload)"
  elif [ "$has_enforce" -eq 0 ] && [ "$has_banner" -eq 0 ] && [ "$has_preload" -eq 0 ]; then
    echo "Hooks: not registered (run 'bocek on')"
  else
    local parts=()
    [ "$has_enforce" -eq 1 ] && parts+=("enforcement") || parts+=("no-enforcement")
    [ "$has_banner" -eq 1 ]  && parts+=("banner")      || parts+=("no-banner")
    [ "$has_preload" -eq 1 ] && parts+=("preload")     || parts+=("no-preload")
    echo "Hooks: partial (${parts[*]}) — run 'bocek on' to reconcile"
  fi

  # Check slash commands
  local COMMANDS_DIR="$PROJECT_ROOT/.claude/commands"
  local cmd_count=0
  if [ -d "$COMMANDS_DIR" ]; then
    for p in "${PRIMITIVES[@]}"; do
      if [ -f "$COMMANDS_DIR/$p.md" ] && head -n 1 "$COMMANDS_DIR/$p.md" | grep -q "$MANAGED_MARKER"; then
        cmd_count=$((cmd_count + 1))
      fi
    done
  fi
  echo "Slash commands: $cmd_count / ${#PRIMITIVES[@]} installed"

  # Check current mode
  local MODE_FILE="$PROJECT_ROOT/.bocek/mode"
  if [ -f "$MODE_FILE" ]; then
    echo "Mode: $(cat "$MODE_FILE")"
  else
    echo "Mode: no mode file"
  fi

  # Check vault state
  local VAULT_DIR="$PROJECT_ROOT/.bocek/vault"
  if [ -d "$VAULT_DIR" ]; then
    local ENTRY_COUNT
    ENTRY_COUNT=$(find "$VAULT_DIR" -name "*.md" | wc -l)
    echo "Vault: $ENTRY_COUNT entries"
    if [ -f "$VAULT_DIR/index.md" ]; then
      local VERSION
      VERSION=$(grep "vault_version" "$VAULT_DIR/index.md" | head -1 | grep -o "[0-9]*")
      echo "Vault version: ${VERSION:-unknown}"
    fi
  else
    echo "Vault: not initialized"
  fi

  # Check primitives
  local PRIMITIVES_DIR="$HOME/.bocek/primitives"
  if [ -d "$PRIMITIVES_DIR" ]; then
    local PRIM_COUNT
    PRIM_COUNT=$(find -L "$PRIMITIVES_DIR" -maxdepth 1 -name "*.md" | wc -l)
    local loc="$PRIMITIVES_DIR"
    [ -L "$PRIMITIVES_DIR" ] && loc="$PRIMITIVES_DIR → $(readlink "$PRIMITIVES_DIR")"
    echo "Primitives: $PRIM_COUNT installed at $loc"
  else
    echo "Primitives: not installed (run 'bocek update' or reinstall)"
  fi
}

cmd_update() {
  local REPO_DIR="$HOME/.bocek/.repo"
  local LEGACY_DIR="$HOME/.bocek/primitives"

  # Legacy install (repo cloned into ~/.bocek/primitives) — tell user to reinstall.
  if [ ! -d "$REPO_DIR/.git" ] && [ -d "$LEGACY_DIR/.git" ] && [ ! -L "$LEGACY_DIR" ]; then
    echo "bocek: detected legacy install layout. Re-run the installer to migrate:" >&2
    echo "  curl -fsSL https://raw.githubusercontent.com/patrickmvla/bocek/main/install.sh | bash" >&2
    exit 1
  fi

  if [ ! -d "$REPO_DIR/.git" ]; then
    echo "bocek: repo not found at $REPO_DIR. Reinstall bocek." >&2
    exit 1
  fi

  cd "$REPO_DIR"
  if git pull --ff-only 2>&1; then
    # Re-copy scripts after update
    cp scripts/bocek "$HOME/.bocek/bin/bocek"
    cp scripts/enforce-mode.sh "$HOME/.bocek/scripts/enforce-mode.sh"
    cp scripts/session-banner.sh "$HOME/.bocek/scripts/session-banner.sh"
    cp scripts/preload-calibration.sh "$HOME/.bocek/scripts/preload-calibration.sh"
    cp scripts/preflight.sh "$HOME/.bocek/scripts/preflight.sh"
    chmod +x "$HOME/.bocek/bin/bocek"
    chmod +x "$HOME/.bocek/scripts/enforce-mode.sh"
    chmod +x "$HOME/.bocek/scripts/session-banner.sh"
    chmod +x "$HOME/.bocek/scripts/preload-calibration.sh"
    chmod +x "$HOME/.bocek/scripts/preflight.sh"
    echo "bocek: primitives and scripts updated."
    # IMPORTANT: exit here, not return. The cp above replaced the script
    # bash is currently executing. If we let the function return, bash
    # tries to read the next byte from the now-different file and hits
    # garbage (line N of the new script at the old byte offset). Exiting
    # here stops the read before that happens.
    exit 0
  else
    echo "bocek: update failed. Check network and try again." >&2
    exit 1
  fi
}

cmd_bootstrap() {
  if [ ! -d "$PROJECT_ROOT/.git" ]; then
    echo "bocek: warning — $PROJECT_ROOT is not a git repo (project-shape entries are usually committed)."
    echo "       Continue anyway? (y/N)"
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]] || exit 0
  fi

  local SHAPE_FILE="$PROJECT_ROOT/.bocek/vault/_shared/project-shape.md"
  if [ -f "$SHAPE_FILE" ]; then
    echo "bocek: project-shape already exists at .bocek/vault/_shared/project-shape.md"
    echo "       Re-bootstrap will overwrite. Continue? (y/N)"
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]] || exit 0
  fi

  echo ""
  echo "=== Bocek Bootstrap — Project Shape ==="
  echo ""
  echo "Capturing the meta-decision that anchors every other decision in this project."
  echo "Answer briefly. Press Enter to leave a section blank — you can edit later."
  echo ""

  local NAME WHAT SCALE_NOW SCALE_6MO SCALE_24MO TEAM CONSTRAINTS NONGOALS SUCCESS
  read -r -p "Project name: " NAME
  echo "What's being built? (one-line description)"
  read -r WHAT
  echo "Current scale (e.g. '1k orders/day, peak 50/min'):"
  read -r SCALE_NOW
  echo "6-month target scale:"
  read -r SCALE_6MO
  echo "24-month aspirational scale (or skip):"
  read -r SCALE_24MO
  echo "Team size and expertise (e.g. '3 backend, strong TS/Postgres, weak distributed-systems'):"
  read -r TEAM
  echo "Hard constraints (latency / regulatory / budget — comma-separated):"
  read -r CONSTRAINTS
  echo "Explicit non-goals (what we're NOT building — comma-separated):"
  read -r NONGOALS
  echo "Success criteria for v1 (how do we know we're done):"
  read -r SUCCESS

  local TODAY
  TODAY=$(date +%Y-%m-%d)
  mkdir -p "$PROJECT_ROOT/.bocek/vault/_shared"

  cat > "$SHAPE_FILE" <<EOF
---
type: decision
features: [_shared]
related: []
created: $TODAY
confidence: high
---

# Project shape: ${NAME:-(unnamed project)}

## What's being built
${WHAT:-_TBD — describe what this system owns and explicitly what it does NOT own._}

## Scale
- **Current:** ${SCALE_NOW:-_TBD_}
- **6-month target:** ${SCALE_6MO:-_TBD_}
- **24-month aspirational:** ${SCALE_24MO:-_TBD — or remove this line if not relevant yet._}

## Team
${TEAM:-_TBD — size, expertise distribution, ownership window._}

## Constraints
${CONSTRAINTS:-_TBD — latency, regulatory, budget, operational._}

## Explicit non-goals
${NONGOALS:-_TBD — what this system is deliberately NOT doing. Non-goals are as load-bearing as goals._}

## Success criteria for v1
${SUCCESS:-_TBD — concrete and measurable: latency holds, drift below threshold, page rate below threshold._}

## Inherited by
Every decision in this vault inherits these constraints. When a proposal violates one, the proposal must either be rejected or this entry must be updated *first* with the named change.

## Revisit when
- Scale assumptions break significantly.
- Team composition changes substantially.
- Constraints change (regulatory, budget, ownership).
- Success criteria drift in priority.
EOF

  # Initialize vault index if missing
  local VAULT_INDEX="$PROJECT_ROOT/.bocek/vault/index.md"
  if [ ! -f "$VAULT_INDEX" ]; then
    cat > "$VAULT_INDEX" <<EOF
---
vault_version: 2
---

# Vault Index

## _shared
- [[project-shape]] — decision — ${NAME:-project} meta-context inherited by every decision
EOF
  fi

  # Initialize CONTEXT.md if missing (per [[context-md-as-vocabulary]])
  local CONTEXT_FILE="$PROJECT_ROOT/.bocek/vault/CONTEXT.md"
  if [ ! -f "$CONTEXT_FILE" ]; then
    cat > "$CONTEXT_FILE" <<EOF
---
vault_version: 2
created: $TODAY
---

# ${NAME:-Project} — Domain Context

<!-- Add project-specific domain terms here as they emerge.
     See ~/.bocek/references/shared/context-format.md for the format.
     This file is read on every primitive activation. -->

## Language

<!-- Example shape — replace with real terms as they emerge during /design or /research:

**TermName:**
One-sentence definition. What it IS, not what it does.
→ see [[feature/slug]]
_Avoid_: alternative-word-1, alternative-word-2
-->

## Relationships

<!-- e.g. - A **Player** has zero or more **Wallets**
         - A **Wallet** holds one **Currency** -->

## Example dialogue

<!-- A short conversation showing how the terms interact naturally. Two-to-four lines. -->

## Flagged ambiguities

<!-- Note here when a term is used ambiguously and which usage won. -->
EOF
  fi

  # Initialize state.md if missing
  local STATE_FILE="$PROJECT_ROOT/.bocek/state.md"
  if [ ! -f "$STATE_FILE" ]; then
    cat > "$STATE_FILE" <<EOF
## Current state
- Feature: _shared (project shape captured)
- Last resolved: [[project-shape]]
- In progress: (no active feature yet)
- Next: pick a feature to start designing
EOF
  fi

  # Initialize mode if missing
  local MODE_FILE="$PROJECT_ROOT/.bocek/mode"
  if [ ! -f "$MODE_FILE" ]; then
    echo "idle" > "$MODE_FILE"
  fi

  echo ""
  echo "bocek: project-shape vaulted at .bocek/vault/_shared/project-shape.md"
  echo "       Edit the file to refine — most users add explicit confidence levels"
  echo "       on scale assumptions and more measurable success criteria."
  echo ""
  echo "Next: open Claude Code in this project and run /design to start the first feature."
}

cmd_vault_organize() {
  local mode="loose"
  case "${1:-}" in
    --migrate-research) mode="research" ;;
    "") ;;
    *) echo "bocek: unknown 'vault organize' flag '${1:-}'. Try: --migrate-research" >&2; exit 1 ;;
  esac

  local VAULT_DIR="$PROJECT_ROOT/.bocek/vault"

  if [ ! -d "$VAULT_DIR" ]; then
    echo "bocek: no vault at $VAULT_DIR — nothing to organize"
    exit 0
  fi

  if [ "$mode" = "research" ]; then
    cmd_vault_organize_research
    return
  fi

  # Find loose entries (top-level .md files that aren't index.md or CONTEXT.md)
  local LOOSE
  LOOSE=$(find "$VAULT_DIR" -mindepth 1 -maxdepth 1 -type f -name "*.md" -not -name "index.md" -not -name "CONTEXT.md" -printf "%f\n" 2>/dev/null | sort)

  if [ -z "$LOOSE" ]; then
    echo "bocek: no loose entries in $VAULT_DIR — vault already follows the path convention"
    exit 0
  fi

  echo "=== Bocek Vault Organize ==="
  echo ""
  echo "Loose entries (in vault/ directly, not in {feature}/ folders):"
  echo "$LOOSE" | sed 's|^|  |'
  echo ""

  local moved=0
  local skipped=0
  local manual=()
  local in_git=0
  [ -d "$PROJECT_ROOT/.git" ] && in_git=1

  while IFS= read -r filename <&3; do
    [ -z "$filename" ] && continue
    local filepath="$VAULT_DIR/$filename"

    # Extract first feature from frontmatter (handles features: [a, b] or features: [a])
    local feature
    feature=$(awk '
      BEGIN { in_fm = 0 }
      /^---$/ { if (in_fm) exit; in_fm = 1; next }
      in_fm && /^features:/ {
        if (match($0, /\[[^]]*\]/)) {
          fs = substr($0, RSTART + 1, RLENGTH - 2)
          n = split(fs, arr, /,[[:space:]]*/)
          if (n > 0) {
            gsub(/^[[:space:]"'"'"']+|[[:space:]"'"'"']+$/, "", arr[1])
            if (length(arr[1]) > 0) {
              print arr[1]
              exit
            }
          }
        }
      }
    ' "$filepath")

    if [ -z "$feature" ]; then
      echo "  $filename: no parseable features: in frontmatter"
      echo "    [s] move to _shared/ (cross-cutting)"
      echo "    [k] skip — fix manually"
      echo -n "    Choice [s/k]: "
      read -r choice
      case "$choice" in
        s|S) feature="_shared" ;;
        *) skipped=$((skipped + 1)); manual+=("$filename"); continue ;;
      esac
    fi

    local target_dir="$VAULT_DIR/$feature"
    local target_path="$target_dir/$filename"

    if [ -e "$target_path" ]; then
      echo "  $filename: target already exists at $feature/$filename — skipping"
      skipped=$((skipped + 1))
      manual+=("$filename")
      continue
    fi

    mkdir -p "$target_dir"

    local rel_src="${filepath#"$PROJECT_ROOT"/}"
    local rel_dst="${target_path#"$PROJECT_ROOT"/}"

    if [ "$in_git" -eq 1 ] && git -C "$PROJECT_ROOT" ls-files --error-unmatch "$rel_src" >/dev/null 2>&1; then
      git -C "$PROJECT_ROOT" mv "$rel_src" "$rel_dst" 2>/dev/null || mv "$filepath" "$target_path"
    else
      mv "$filepath" "$target_path"
    fi

    echo "  $filename → $feature/$filename"
    moved=$((moved + 1))
  done 3<<< "$LOOSE"

  echo ""
  echo "bocek: $moved entries organized; $skipped skipped"
  if [ "${#manual[@]}" -gt 0 ]; then
    echo "       Manual review needed for: ${manual[*]}"
  fi
  echo ""
  echo "Wikilinks ([[name]]) still resolve — they're filename-based, not path-based."
  echo "Review .bocek/vault/index.md if any entries are listed by path rather than wikilink."
}

# Migrate type:research entries from flat feature-folder paths into .research/ subfolders
# (per [[research-subfolder]]). Walks each feature folder, identifies entries with
# `type: research` in frontmatter at depth 2, moves them into .research/ via `git mv`
# when the repo tracks them, plain mv otherwise.
cmd_vault_organize_research() {
  local VAULT_DIR="$PROJECT_ROOT/.bocek/vault"

  echo "=== Bocek Vault Organize — Research Subfolder Migration ==="
  echo ""
  echo "Scanning for type:research entries at flat feature-folder paths..."
  echo ""

  local moved=0
  local skipped=0
  local in_git=0
  [ -d "$PROJECT_ROOT/.git" ] && in_git=1

  while IFS= read -r feature_dir; do
    [ -z "$feature_dir" ] && continue
    local feature
    feature=$(basename "$feature_dir")

    while IFS= read -r entry; do
      [ -z "$entry" ] && continue

      # Skip if already in .research/
      case "$entry" in
        */.research/*) continue ;;
      esac

      # Extract type from frontmatter
      local type
      type=$(awk '/^---$/{if(c)exit;c=1;next} c && /^type:/{print $2; exit}' "$entry" 2>/dev/null | tr -d '[:space:]')

      if [ "$type" = "research" ]; then
        local target_dir="$feature_dir/.research"
        local target_path="$target_dir/$(basename "$entry")"

        if [ -e "$target_path" ]; then
          echo "  $feature/$(basename "$entry"): target already exists at $feature/.research/$(basename "$entry") — skipping"
          skipped=$((skipped + 1))
          continue
        fi

        mkdir -p "$target_dir"

        local rel_src="${entry#"$PROJECT_ROOT"/}"
        local rel_dst="${target_path#"$PROJECT_ROOT"/}"

        if [ "$in_git" -eq 1 ] && git -C "$PROJECT_ROOT" ls-files --error-unmatch "$rel_src" >/dev/null 2>&1; then
          git -C "$PROJECT_ROOT" mv "$rel_src" "$rel_dst" 2>/dev/null || mv "$entry" "$target_path"
        else
          mv "$entry" "$target_path"
        fi

        echo "  $feature/$(basename "$entry") → $feature/.research/$(basename "$entry")"
        moved=$((moved + 1))
      fi
    done < <(find "$feature_dir" -mindepth 1 -maxdepth 1 -type f -name "*.md" 2>/dev/null)
  done < <(find "$VAULT_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)

  echo ""
  echo "bocek: $moved type:research entries migrated into .research/; $skipped skipped"
  echo ""
  echo "Wikilinks ([[name]]) still resolve — filename-based, not path-based."
}

# Regenerate .bocek/vault/index.md from per-entry summaries per [[index-regen-from-frontmatter]].
# Resolution order for each entry's summary: frontmatter `description:` → first H1 heading → slug-as-title-case.
# Hand-edits to index.md are clobbered by the next rebuild — the script is the source of truth.
# Usage: bocek vault index [--rebuild | --check]
cmd_vault_index_rebuild() {
  local mode="rebuild"
  case "${1:-}" in
    --rebuild|"") mode="rebuild" ;;
    --check) mode="check" ;;
    *) echo "bocek: unknown 'vault index' flag '${1:-}'. Try: --rebuild or --check" >&2; exit 1 ;;
  esac

  local VAULT_DIR="$PROJECT_ROOT/.bocek/vault"

  if [ ! -d "$VAULT_DIR" ]; then
    echo "bocek: no vault at $VAULT_DIR — nothing to rebuild" >&2
    exit 0
  fi

  # Project name from CONTEXT.md H1 if present, else "Vault"
  local PROJECT_NAME="Vault"
  if [ -f "$VAULT_DIR/CONTEXT.md" ]; then
    local extracted
    extracted=$(awk '/^# /{sub(/^# /, ""); sub(/ — .*/, ""); print; exit}' "$VAULT_DIR/CONTEXT.md" 2>/dev/null)
    [ -n "$extracted" ] && PROJECT_NAME="$extracted"
  fi

  local tmpfile
  tmpfile=$(mktemp)
  trap "rm -f '$tmpfile'" RETURN

  printf -- '---\nvault_version: 2\n---\n\n# %s Index\n' "$PROJECT_NAME" > "$tmpfile"

  local missing_desc=0
  local missing_list=""
  local current_feature=""

  process_entry() {
    local entry="$1"
    local rel="${entry#"$VAULT_DIR"/}"
    local feature="${rel%%/*}"

    if [ "$feature" != "$current_feature" ]; then
      printf -- '\n## %s\n\n' "$feature" >> "$tmpfile"
      current_feature="$feature"
    fi

    local type
    type=$(awk '/^---$/{if(c)exit;c=1;next} c && /^type:/{print $2;exit}' "$entry" 2>/dev/null | tr -d '[:space:]')
    [ -z "$type" ] && type="?"

    local desc
    desc=$(awk '/^---$/{if(c)exit;c=1;next} c && /^description:/{sub(/^description:[[:space:]]*/, ""); print; exit}' "$entry" 2>/dev/null)
    if [ -z "$desc" ]; then
      missing_desc=$((missing_desc + 1))
      missing_list+="  $entry"$'\n'
      desc=$(awk '/^# /{sub(/^# /, ""); print; exit}' "$entry" 2>/dev/null)
      if [ -z "$desc" ]; then
        local base
        base=$(basename "$entry" .md)
        desc=$(printf '%s' "$base" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))} 1')
      fi
    fi

    if [ ${#desc} -gt 200 ]; then
      desc="${desc:0:197}..."
    fi

    local wikilink
    wikilink=$(basename "$entry" .md)

    printf -- '- [[%s]] — type: %s — %s\n' "$wikilink" "$type" "$desc" >> "$tmpfile"
  }

  # _shared/ first (with .research/ sub-entries)
  if [ -d "$VAULT_DIR/_shared" ]; then
    while IFS= read -r entry; do
      [ -z "$entry" ] && continue
      process_entry "$entry"
    done < <(find "$VAULT_DIR/_shared" -mindepth 1 -maxdepth 2 -type f -name "*.md" 2>/dev/null | sort)
  fi

  # Then other feature folders, alphabetically
  while IFS= read -r feature_dir; do
    [ -z "$feature_dir" ] && continue
    while IFS= read -r entry; do
      [ -z "$entry" ] && continue
      process_entry "$entry"
    done < <(find "$feature_dir" -mindepth 1 -maxdepth 2 -type f -name "*.md" 2>/dev/null | sort)
  done < <(find "$VAULT_DIR" -mindepth 1 -maxdepth 1 -type d -not -name "_shared" 2>/dev/null | sort)

  if [ "$mode" = "check" ]; then
    echo "=== Bocek Vault Index — Check (dry run) ==="
    echo ""
    cat "$tmpfile"
    if [ "$missing_desc" -gt 0 ]; then
      printf '\nWARNING: %d entries lack `description:` frontmatter (fell back to H1 heading or slug):\n%s' \
        "$missing_desc" "$missing_list"
    fi
  else
    cp "$tmpfile" "$VAULT_DIR/index.md"
    echo "bocek: vault index rebuilt at $VAULT_DIR/index.md"
    if [ "$missing_desc" -gt 0 ]; then
      echo "       $missing_desc entries lack 'description:' frontmatter (fell back to H1 heading or slug)."
      echo "       Run 'bocek vault index --check' to see which entries."
    fi
  fi
}

# --- Usage ---
usage() {
  echo "Usage: bocek <command>"
  echo ""
  echo "Commands:"
  echo "  on               Register Bocek hooks in this project"
  echo "  off              Remove Bocek hooks from this project"
  echo "  status           Show Bocek status for this project"
  echo "  update           Update primitives and scripts from remote"
  echo "  bootstrap        Interactive project-shape interview (greenfield onboarding)"
  echo "  vault organize   Move loose vault entries into {feature}/ folders"
  echo ""
}

# --- Dispatch ---
case "${1:-}" in
  on)        cmd_on ;;
  off)       cmd_off ;;
  status)    cmd_status ;;
  update)    cmd_update ;;
  bootstrap) cmd_bootstrap ;;
  vault)
    case "${2:-}" in
      organize|organise) cmd_vault_organize "${3:-}" ;;
      index) cmd_vault_index_rebuild "${3:-}" ;;
      *) echo "bocek: unknown vault subcommand '${2:-}'. Try: bocek vault organize [--migrate-research] | bocek vault index [--rebuild|--check]" >&2; exit 1 ;;
    esac
    ;;
  *)         usage; exit 1 ;;
esac
