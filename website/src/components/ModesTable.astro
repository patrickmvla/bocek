---
const modes = [
  {
    name: "design",
    kind: "reasoning",
    demand:
      "Asked to wield ACID, CAP, isolation levels, failure semantics. Three gates per position: idiomatic, industry-standard, first-class. Adversarial only when calibrated.",
  },
  {
    name: "research",
    kind: "reasoning",
    demand:
      "Triangulates production code + version-pinned docs + a contradiction probe. Source-quality tier per claim. Operational implications spelled out.",
  },
  {
    name: "implementation",
    kind: "code",
    demand:
      "Ships from a complete vault, citing the contract and idiom file inline. Every choice not in the contract gets flagged, never picked.",
  },
  {
    name: "debugging",
    kind: "code",
    demand:
      "Evidence-grounded. Failure lenses + five-whys. A fix isn't done unless you can explain why it failed AND why this fixes it.",
  },
  {
    name: "refactoring",
    kind: "code",
    demand:
      "Named upcoming change as justification. Test coverage as precondition. Each step independently reversible. No slipped-in improvements.",
  },
  {
    name: "review",
    kind: "reasoning",
    demand:
      "Drift detection — every vault entry traced. Findings classified (drift / gap / orphan), severity rationaled, reproducible.",
  },
];
---

<div class="overflow-hidden rounded-lg border border-border/60">
  <table class="w-full border-collapse text-left text-sm">
    <thead>
      <tr class="bg-background-alt/60">
        <th
          scope="col"
          class="w-[28%] border-b border-border/60 px-5 py-3 font-heading text-[10px] font-semibold uppercase tracking-[0.22em] text-muted-foreground"
          >mode</th
        >
        <th
          scope="col"
          class="w-[14%] border-b border-border/60 px-5 py-3 font-heading text-[10px] font-semibold uppercase tracking-[0.22em] text-muted-foreground"
          >kind</th
        >
        <th
          scope="col"
          class="border-b border-border/60 px-5 py-3 font-heading text-[10px] font-semibold uppercase tracking-[0.22em] text-muted-foreground"
          >what it demands</th
        >
      </tr>
    </thead>
    <tbody>
      {
        modes.map((m, i) => (
          <tr
            class={
              i < modes.length - 1
                ? "border-b border-border/40 transition-colors hover:bg-background-alt/40"
                : "transition-colors hover:bg-background-alt/40"
            }
          >
            <td class="px-5 py-4 align-top">
              <span class="font-heading text-sm font-semibold tracking-tight text-foreground">
                {m.name}
              </span>
            </td>
            <td class="px-5 py-4 align-top">
              <span
                class={`font-heading text-[10px] uppercase tracking-[0.2em] ${
                  m.kind === "reasoning"
                    ? "text-[color:var(--accent-amber)]"
                    : "text-muted-foreground"
                }`}
              >
                {m.kind}
              </span>
            </td>
            <td class="px-5 py-4 align-top text-sm leading-relaxed text-muted-foreground">
              {m.demand}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
