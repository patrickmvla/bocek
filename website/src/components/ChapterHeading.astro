---
interface Props {
  number: string;
  title: string;
  kicker?: string;
  id?: string;
  /** "default" = --background. "alt" = --background-alt for banded rhythm. */
  variant?: "default" | "alt";
}

const {
  number,
  title,
  kicker,
  id,
  variant = "default",
} = Astro.props;

const bg = variant === "alt" ? "bg-background-alt" : "bg-background";
---

<section id={id} class={`${bg} relative`}>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <div class="mb-10 flex items-baseline gap-5">
      <span
        aria-hidden="true"
        class="font-heading text-sm font-semibold tracking-[0.2em] text-[color:var(--accent-amber)]"
      >
        {number}
      </span>
      <span class="h-px flex-1 bg-border/60"></span>
      {kicker && (
        <span class="font-heading text-[10px] uppercase tracking-[0.25em] text-muted-foreground">
          {kicker}
        </span>
      )}
    </div>
    <h2 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
      {title}
    </h2>
    <div class="mt-8">
      <slot />
    </div>
  </div>
</section>
